    "uishot-skills": "workspace:*",
    "commander": "^13.0.0",
    "playwright": "^1.50.0",
    "yaml": "^2.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TimCrooker/uishot.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/TimCrooker/uishot#readme",
  "bugs": "https://github.com/TimCrooker/uishot/issues"
}
