{
  "name": "uishot",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Instant, addressable UI screenshots for AI agents",
  "bin": {
    "uishot": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
