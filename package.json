{
  "name": "uishot-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=20.11.0" },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
